{
  "gboost_classifier": {
    "n_estimators": 150,
    "learning_rate": 0.08,
    "max_depth": 6,
    "subsample": 0.85,
    "random_state": 42,
    "min_samples_split": 5,
    "min_samples_leaf": 2,
    "max_features": "sqrt",
    "validation_fraction": 0.1,
    "n_iter_no_change": 10,
    "tol": 1e-4
  },
  "lstm_model": {
    "n_steps": 8,
    "n_units": 128,
    "dropout_rate": 0.25,
    "learning_rate": 0.0005,
    "epochs": 50,
    "batch_size": 16,
    "validation_split": 0.15,
    "early_stopping_patience": 12,
    "reduce_lr_patience": 6,
    "reduce_lr_factor": 0.5,
    "reduce_lr_min": 1e-7,
    "use_batch_norm": true,
    "scaler_type": "minmax",
    "number_range": [1, 40],
    "number_count": 6
  },
  "transformer_model": {
    "d_model": 256,
    "nhead": 8,
    "num_layers": 4,
    "dropout": 0.15,
    "sequence_length": 12,
    "num_numbers": 40,
    "learning_rate": 0.001,
    "weight_decay": 0.01,
    "batch_size": 32,
    "epochs": 30,
    "warmup_steps": 100
  },
  "arima_cycles": {
    "window_short": 5,
    "window_long": 20,
    "variance_weight": 2.0,
    "trend_weight": 10.0,
    "min_score": 0.3,
    "max_score": 2.0,
    "default_fallback_range": [0.8, 1.2]
  },
  "general": {
    "random_seed": 42,
    "use_gpu": true,
    "model_save_interval": 10,
    "log_level": "INFO",
    "enable_tensorboard": false,
    "validation_metric": "accuracy",
    "cross_validation_folds": 5
  }
}