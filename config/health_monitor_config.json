{
  "monitoring": {
    "check_interval_seconds": 300,
    "alert_interval_minutes": 15,
    "history_retention_hours": 24,
    "consecutive_failure_threshold": 3
  },
  "thresholds": {
    "cpu_percent": 85.0,
    "memory_percent": 80.0,
    "disk_usage_percent": 90.0,
    "response_time_ms": 5000.0,
    "process_memory_mb": 1024.0
  },
  "alerts": {
    "enabled": true,
    "channels": [
      "email",
      "console"
    ],
    "severity_levels": [
      "critical",
      "warning"
    ],
    "cooldown_minutes": 30
  },
  "services": {
    "mcp_integration": {
      "enabled": true,
      "critical": true
    },
    "lottery_data_service": {
      "enabled": true,
      "critical": false
    },
    "notification_service": {
      "enabled": true,
      "critical": false
    },
    "workflow_automation": {
      "enabled": true,
      "critical": false
    },
    "system_resources": {
      "enabled": true,
      "critical": true
    },
    "process_health": {
      "enabled": true,
      "critical": true
    },
    "api_connectivity": {
      "enabled": true,
      "critical": false
    },
    "data_integrity": {
      "enabled": true,
      "critical": false
    }
  }
}