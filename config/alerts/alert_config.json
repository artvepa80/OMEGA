{
  "alert_rules": [
    {
      "name": "model_timeout_critical",
      "condition": "threshold",
      "metric": "execution_time",
      "threshold_value": 30.0,
      "comparison": "gt",
      "severity": "critical",
      "cooldown_minutes": 2,
      "enabled": true,
      "description": "Modelo excedi\u00f3 30 segundos de ejecuci\u00f3n",
      "action": null,
      "ml_sensitivity": 0.1,
      "security_level": "standard",
      "encrypted": false
    },
    {
      "name": "model_timeout_warning",
      "condition": "threshold",
      "metric": "execution_time",
      "threshold_value": 20.0,
      "comparison": "gt",
      "severity": "warning",
      "cooldown_minutes": 3,
      "enabled": true,
      "description": "Modelo tard\u00f3 m\u00e1s de 20 segundos",
      "action": null,
      "ml_sensitivity": 0.1,
      "security_level": "standard",
      "encrypted": false
    },
    {
      "name": "low_success_rate",
      "condition": "threshold",
      "metric": "success_rate",
      "threshold_value": 0.7,
      "comparison": "lt",
      "severity": "warning",
      "cooldown_minutes": 5,
      "enabled": true,
      "description": "Tasa de \u00e9xito del modelo por debajo del 70%",
      "action": null,
      "ml_sensitivity": 0.1,
      "security_level": "standard",
      "encrypted": false
    },
    {
      "name": "high_memory_usage",
      "condition": "threshold",
      "metric": "memory_percent",
      "threshold_value": 85.0,
      "comparison": "gt",
      "severity": "warning",
      "cooldown_minutes": 1,
      "enabled": true,
      "description": "Uso de memoria superior al 85%",
      "action": null,
      "ml_sensitivity": 0.1,
      "security_level": "standard",
      "encrypted": false
    },
    {
      "name": "critical_memory_usage",
      "condition": "threshold",
      "metric": "memory_percent",
      "threshold_value": 95.0,
      "comparison": "gt",
      "severity": "critical",
      "cooldown_minutes": 1,
      "enabled": true,
      "description": "Uso cr\u00edtico de memoria superior al 95%",
      "action": null,
      "ml_sensitivity": 0.1,
      "security_level": "standard",
      "encrypted": false
    },
    {
      "name": "high_cpu_usage",
      "condition": "threshold",
      "metric": "cpu_percent",
      "threshold_value": 90.0,
      "comparison": "gt",
      "severity": "warning",
      "cooldown_minutes": 2,
      "enabled": true,
      "description": "Uso de CPU superior al 90%",
      "action": null,
      "ml_sensitivity": 0.1,
      "security_level": "standard",
      "encrypted": false
    },
    {
      "name": "frequent_fallbacks",
      "condition": "threshold",
      "metric": "fallback_count",
      "threshold_value": 3.0,
      "comparison": "gte",
      "severity": "warning",
      "cooldown_minutes": 10,
      "enabled": true,
      "description": "Modelo usando fallbacks frecuentemente",
      "action": null,
      "ml_sensitivity": 0.1,
      "security_level": "standard",
      "encrypted": false
    },
    {
      "name": "performance_degradation",
      "condition": "trend",
      "metric": "execution_time",
      "threshold_value": 0.3,
      "comparison": "gt",
      "severity": "warning",
      "cooldown_minutes": 15,
      "enabled": true,
      "description": "Degradaci\u00f3n de rendimiento detectada",
      "action": null,
      "ml_sensitivity": 0.1,
      "security_level": "standard",
      "encrypted": false
    },
    {
      "name": "lstm_accuracy_critical",
      "condition": "threshold",
      "metric": "lstm_accuracy",
      "threshold_value": 0.65,
      "comparison": "lt",
      "severity": "critical",
      "cooldown_minutes": 5,
      "enabled": true,
      "description": "LSTM accuracy below critical 65% threshold",
      "action": "secure_email",
      "ml_sensitivity": 0.1,
      "security_level": "high",
      "encrypted": false
    },
    {
      "name": "ml_anomaly_detected",
      "condition": "ml_anomaly",
      "metric": "execution_time",
      "threshold_value": 0.1,
      "comparison": "gt",
      "severity": "warning",
      "cooldown_minutes": 10,
      "enabled": true,
      "description": "ML anomaly detection: unusual pattern detected",
      "action": null,
      "ml_sensitivity": 0.1,
      "security_level": "standard",
      "encrypted": false
    },
    {
      "name": "model_accuracy_degradation",
      "condition": "accuracy_drop",
      "metric": "model_accuracy",
      "threshold_value": 0.1,
      "comparison": "gt",
      "severity": "warning",
      "cooldown_minutes": 15,
      "enabled": true,
      "description": "Model accuracy degradation detected",
      "action": null,
      "ml_sensitivity": 0.1,
      "security_level": "standard",
      "encrypted": false
    }
  ],
  "email_config": {}
}