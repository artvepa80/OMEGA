# OMEGA PRO AI - Enhanced Performance Alerts Configuration
# Copy this file to .env and configure your settings

# Secure Email Configuration
OMEGA_EMAIL_ENABLED=false
OMEGA_SMTP_HOST=smtp.gmail.com
OMEGA_SMTP_PORT=587
OMEGA_SENDER_EMAIL=your-omega-alerts@example.com
OMEGA_SENDER_PASSWORD=your-app-password-here
OMEGA_EMAIL_RECIPIENTS=admin@example.com,ops@example.com,security@example.com
OMEGA_SMTP_TLS=true
OMEGA_SMTP_SSL=false
OMEGA_SMTP_TIMEOUT=30

# Security Configuration
OMEGA_ALERT_ENCRYPTION_KEY=your-32-byte-encryption-key-here
OMEGA_SECURITY_MODE=high
OMEGA_LOG_LEVEL=INFO

# ML Configuration
OMEGA_ML_ANOMALY_DETECTION=true
OMEGA_ML_TRAINING_WINDOW=50
OMEGA_ML_CONTAMINATION_RATE=0.1

# LSTM Accuracy Monitoring
OMEGA_LSTM_CRITICAL_THRESHOLD=0.65
OMEGA_LSTM_WARNING_THRESHOLD=0.70
OMEGA_ACCURACY_MONITORING=true

# Performance Monitoring
OMEGA_ALERT_HISTORY_SIZE=1000
OMEGA_METRIC_HISTORY_SIZE=100
OMEGA_THREAD_POOL_SIZE=4

# Production Settings
OMEGA_PRODUCTION_MODE=false
OMEGA_DEBUG_ALERTS=false
OMEGA_ALERT_RATE_LIMIT=true