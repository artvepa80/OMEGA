{
  "dashboard": {
    "id": null,
    "title": "OMEGA AI System Dashboard",
    "tags": ["omega", "ai", "lottery", "conversational"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Message Processing Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(conversational_ai_messages_total[5m])",
            "legendFormat": "{{intent}} - {{language}}"
          }
        ],
        "yAxes": [
          {
            "label": "Messages/sec",
            "min": 0
          }
        ],
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Response Times",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, conversational_ai_response_time_seconds_bucket)",
            "legendFormat": "95th percentile"
          },
          {
            "expr": "histogram_quantile(0.50, conversational_ai_response_time_seconds_bucket)",
            "legendFormat": "Median"
          }
        ],
        "yAxes": [
          {
            "label": "Seconds",
            "min": 0
          }
        ],
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Active Sessions",
        "type": "singlestat",
        "targets": [
          {
            "expr": "conversational_ai_active_sessions"
          }
        ],
        "valueName": "current",
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 0,
          "y": 9
        }
      },
      {
        "id": 4,
        "title": "Intent Confidence",
        "type": "gauge",
        "targets": [
          {
            "expr": "conversational_ai_intent_confidence"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "unit": "percentunit"
          }
        },
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 6,
          "y": 9
        }
      },
      {
        "id": 5,
        "title": "Cache Hit Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(conversational_ai_cache_hits_total[5m])",
            "legendFormat": "{{type}} cache hits"
          }
        ],
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 12,
          "y": 9
        }
      },
      {
        "id": 6,
        "title": "Error Rates",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(conversational_ai_errors_total[5m])",
            "legendFormat": "{{error_type}} errors"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 15
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s"
  }
}