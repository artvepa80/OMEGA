{
  "meta_learning_optimization_config": {
    "version": "1.0",
    "timestamp": "2025-08-16",
    "description": "Optimized configuration for meta-learning system based on execution context analysis",
    
    "entropy_thresholds": {
      "very_high": 0.99,
      "high": 0.95,
      "moderate": 0.7,
      "low": 0.5
    },
    
    "trend_strength_thresholds": {
      "strong": 0.3,
      "moderate": 0.1,
      "weak": 0.05,
      "none": 0.01
    },
    
    "variance_thresholds": {
      "high": 6.0,
      "moderate": 3.0,
      "low": 1.0
    },
    
    "weight_optimization_rules": {
      "high_entropy_scenario": {
        "description": "For entropy > 0.95 with no clear trends",
        "conditions": {
          "entropy_min": 0.95,
          "trend_strength_max": 0.1
        },
        "weight_adjustments": {
          "montecarlo": 1.4,
          "genetic": 1.3,
          "ensemble_ai": 1.2,
          "clustering": 0.7,
          "lstm_v2": 0.6,
          "transformer": 0.6,
          "gboost": 1.0
        },
        "rationale": "Probabilistic models work better with high randomness"
      },
      
      "moderate_balanced_high_entropy": {
        "description": "Moderate balanced regime with very high entropy",
        "conditions": {
          "regime": "moderate_balanced",
          "entropy_min": 0.95
        },
        "weight_adjustments": {
          "ensemble_ai": 1.3,
          "montecarlo": 1.1,
          "genetic": 1.1,
          "lstm_v2": 0.8,
          "transformer": 0.8,
          "clustering": 0.9,
          "gboost": 1.0
        },
        "rationale": "Balanced approach with emphasis on ensemble diversity"
      },
      
      "no_trend_adjustment": {
        "description": "Additional adjustments when trend strength < 0.1",
        "conditions": {
          "trend_strength_max": 0.1
        },
        "weight_adjustments": {
          "lstm_v2": 0.8,
          "transformer": 0.8,
          "montecarlo": 1.2,
          "genetic": 1.1
        },
        "rationale": "Sequential models less effective without trends"
      },
      
      "high_variance_scenario": {
        "description": "High variance patterns require robust models",
        "conditions": {
          "variance_min": 5.0
        },
        "weight_adjustments": {
          "ensemble_ai": 1.2,
          "gboost": 1.1,
          "montecarlo": 1.1,
          "clustering": 0.9
        },
        "rationale": "Ensemble methods handle variance better"
      }
    },
    
    "confidence_enhancement_rules": {
      "high_entropy_penalty": {
        "condition": "entropy > 0.95",
        "confidence_multiplier": 0.8,
        "rationale": "High randomness reduces prediction confidence"
      },
      
      "low_entropy_bonus": {
        "condition": "entropy < 0.5",
        "confidence_multiplier": 1.2,
        "rationale": "Predictable patterns increase confidence"
      },
      
      "trend_bonus": {
        "condition": "trend_strength > 0.1",
        "confidence_multiplier": 1.1,
        "rationale": "Clear trends increase confidence"
      },
      
      "no_trend_penalty": {
        "condition": "trend_strength < 0.01",
        "confidence_multiplier": 0.9,
        "rationale": "No trends reduce confidence"
      },
      
      "balanced_high_entropy_penalty": {
        "condition": "regime = moderate_balanced AND entropy > 0.95",
        "confidence_multiplier": 0.85,
        "rationale": "Balanced regime with high randomness is uncertain"
      }
    },
    
    "reinforcement_learning_config": {
      "high_entropy_mode": {
        "description": "RL behavior in high entropy scenarios",
        "entropy_threshold": 0.95,
        "model_preferences": {
          "avoid_weight_increase": ["lstm_v2", "transformer"],
          "prefer_threshold_adjust": true,
          "favor_models": ["montecarlo", "genetic", "ensemble_ai"]
        }
      },
      
      "context_features": {
        "primary": ["entropy", "variance", "trend_strength"],
        "secondary": ["profiler_confidence", "normalized_variance"],
        "flags": ["high_entropy_flag", "no_trend_flag"]
      }
    },
    
    "integration_settings": {
      "prediction_target": 8,
      "confidence_range": [0.1, 1.0],
      "processing_timeout": 30.0,
      "fallback_confidence": 0.4,
      
      "component_priorities": {
        "meta_controller": 1,
        "profiler": 2, 
        "lstm_v2": 3,
        "reinforcement": 4
      },
      
      "validation_thresholds": {
        "min_predictions": 8,
        "min_avg_confidence": 0.4,
        "max_processing_time": 5.0
      }
    },
    
    "logging_config": {
      "context_analysis": {
        "show_entropy": true,
        "show_regime": true,
        "show_trend_strength": true,
        "show_variance": true
      },
      
      "weight_optimization": {
        "show_adjustments": true,
        "highlight_highest": true,
        "show_rationale": false
      },
      
      "component_results": {
        "show_profiler": true,
        "show_rl_action": true,
        "show_lstm_status": true
      }
    },
    
    "performance_targets": {
      "high_entropy_scenarios": {
        "target_confidence": 0.6,
        "max_processing_time": 2.0,
        "required_predictions": 8
      },
      
      "moderate_scenarios": {
        "target_confidence": 0.7,
        "max_processing_time": 1.5,
        "required_predictions": 8
      },
      
      "low_entropy_scenarios": {
        "target_confidence": 0.8,
        "max_processing_time": 1.0,
        "required_predictions": 8
      }
    }
  }
}