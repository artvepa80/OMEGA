# 🚀 OMEGA PRO AI v10.1 - Git Ignore Configuration
# Excludes sensitive and large files from version control

# ================================================================================================
# SENSITIVE CONFIGURATION FILES (Never commit these!)
# ================================================================================================
.env                           # Environment variables with secrets
.env.local                     # Local environment overrides
.env.production               # Production environment
.env.*.local                  # Environment-specific locals
config/credentials.json       # API credentials
config/secrets.json           # Secret configuration
*.key                         # Private keys
*.pem                         # SSL certificates
*.p12                         # Certificate files
ssl/private/                  # SSL private directory

# ================================================================================================
# BUILD & DEPLOYMENT FILES
# ================================================================================================
*.log                         # Log files
logs/                         # Log directory
temp/                         # Temporary files
*.tmp                         # Temp files
.cache/                       # Cache directory
dist/                         # Distribution builds
build/                        # Build output
node_modules/                 # Node.js dependencies

# ================================================================================================
# PYTHON ARTIFACTS
# ================================================================================================
__pycache__/                  # Python cache
*.pyc                         # Compiled Python
*.pyo                         # Optimized Python
*.pyd                         # Python DLL
.Python                       # Python executable
env/                          # Virtual environments
venv/                         # Virtual environments
.venv/                        # Virtual environments
*.egg-info/                   # Package info
.pytest_cache/                # Pytest cache

# ================================================================================================
# DATA & MODEL FILES (Too large for git)
# ================================================================================================
# Large CSV files
genetic_convergence_*.csv
top_decades_*.csv
*.zip
backup/

# Model files (if too large)
models/*.pkl                  # Pickle models
models/*.pt                   # PyTorch models
models/*.h5                   # Keras models
models/*.model                # Generic models
*.joblib                      # Joblib files
checkpoints/                  # Model checkpoints

# Training data
data/large_datasets/          # Large dataset directory
*.parquet                     # Parquet files
*.feather                     # Feather files

# ================================================================================================
# SYSTEM & IDE FILES
# ================================================================================================
# macOS
.DS_Store                     # macOS folder settings
.AppleDouble                  # macOS resource forks
.LSOverride                   # macOS folder view settings
.Spotlight-V100               # macOS Spotlight
.Trashes                      # macOS trash
.fseventsd                    # macOS file system events
.VolumeIcon.icns             # macOS volume icons
.AppleDB                      # macOS AppleDB
.AppleDesktop                 # macOS AppleDesktop

# Windows
Thumbs.db                     # Windows thumbnails
ehthumbs.db                   # Windows thumbnails
Desktop.ini                   # Windows desktop settings
$RECYCLE.BIN/                # Windows recycle bin

# Linux
.directory                    # Linux folder settings

# IDE & Editors
.vscode/                      # VS Code settings
.idea/                        # IntelliJ/PyCharm
*.sublime-*                   # Sublime Text
*.atom/                       # Atom editor
.spyderproject                # Spyder IDE
.spyproject                   # Spyder IDE

# ================================================================================================
# DOCKER & DEPLOYMENT
# ================================================================================================
Dockerfile.local             # Local Docker configs
docker-compose.override.yml  # Docker compose overrides
.dockerignore.local          # Local Docker ignore

# ================================================================================================
# MONITORING & DEBUGGING
# ================================================================================================
*.prof                       # Profiling files
*.trace                      # Trace files
.coverage                    # Coverage files
htmlcov/                     # Coverage HTML
.nyc_output/                 # NYC coverage
coverage/                    # Coverage directory

# Debug files
*.debug                      # Debug files
core                         # Core dumps
*.dmp                        # Dump files

# ================================================================================================
# DATABASE & RUNTIME
# ================================================================================================
*.db                         # Database files
*.sqlite                     # SQLite databases
*.sqlite3                    # SQLite databases
redis.conf.local            # Local Redis config

# ================================================================================================
# SECURITY & TESTING
# ================================================================================================
.pytest_cache/              # Pytest cache
.tox/                       # Tox environments
.coverage                   # Coverage data
.hypothesis/                # Hypothesis testing

# Security scan results
security-report.*           # Security reports
bandit-report.*            # Bandit reports
safety-report.*            # Safety reports

# ================================================================================================
# CI/CD & DOCKER ARTIFACTS
# ================================================================================================
# GitHub Actions artifacts are handled by GitHub
# But exclude any local CI artifacts
ci-artifacts/               # CI artifacts
test-results/              # Test results
build-reports/             # Build reports

# Docker-related files
docker-compose.*.yml       # Environment-specific compose files
.docker/                   # Docker build cache
docker-data/               # Docker volumes data
.buildkit-cache/           # Docker buildkit cache

# Akash Network deployment
akash-deployment.yaml      # Generated deployment file
akash-state/               # Akash state files
*.lease                    # Lease files
akash-keys/                # Akash wallet keys
akash-temp/                # Temporary akash files

# GitHub Actions secrets backup (never commit!)
.github-secrets/           # Secrets backup
github-token.*             # GitHub tokens
docker-credentials.*       # Docker Hub credentials

# ================================================================================================
# NOTES & TEMPORARY DOCUMENTATION
# ================================================================================================
TODO.md                    # Personal todos
NOTES.md                   # Personal notes
TEMP_*                     # Temporary files
DRAFT_*                    # Draft files
*.bak                      # Backup files
*.backup                   # Backup files
*~                         # Editor backups

# ================================================================================================
# OMEGA SPECIFIC EXCLUSIONS
# ================================================================================================
# Large result files
results/large_datasets/    # Large result datasets
output_*.json             # Large output files
predictions_backup_*      # Backup predictions

# Runtime generated files
omega_runtime_*.log       # Runtime logs
execution_trace_*.json    # Execution traces
performance_*.csv         # Performance data

# Local development
local_test_*              # Local test files
dev_experiments/          # Development experimentsOMEGA_COMPLETE/bin/provider-services
*.pack
*.idx
