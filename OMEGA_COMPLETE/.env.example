# OMEGA PRO AI - Environment Configuration Template

# Application Settings
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info
PORT=8000

# Database Configuration
DATABASE_URL=postgresql://omega:omega123@localhost:5432/omega_db
REDIS_URL=redis://localhost:6379

# Security & Authentication
OAUTH_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Services
CLAUDE_API_KEY=your_claude_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Sports Betting APIs
ODDS_API_KEY=your_odds_api_key
RAPIDAPI_KEY=your_rapidapi_key

# Asian Markets APIs
BETINASIA_API_KEY=your_betinasia_api_key
ISPORTS_API_KEY=your_isports_api_key
SBOBET_API_KEY=your_sbobet_api_key

# Payment Processing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_API_SECRET=your_coinbase_api_secret

# Cryptocurrency Wallets (Use secure key management in production)
BTC_WALLET_ADDRESS=your_btc_wallet_address
ETH_WALLET_ADDRESS=your_eth_wallet_address
WALLET_PRIVATE_KEYS_ENCRYPTED=encrypted_private_keys

# Monitoring & Analytics
SENTRY_DSN=your_sentry_dsn
PROMETHEUS_ENABLED=true
GRAFANA_PASSWORD=secure_grafana_password

# Feature Flags
LOTTERY_PREDICTIONS_ENABLED=true
SPORTS_BETTING_ENABLED=true
ASIAN_MARKETS_ENABLED=true
CONVERSATIONAL_AI_ENABLED=true
CRYPTO_PAYMENTS_ENABLED=true
KYC_VERIFICATION_ENABLED=true

# Localization
SUPPORTED_LANGUAGES=en,zh,ja,ko,th,hi
DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=USD

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100

# Email Configuration (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password

# Webhook URLs
WEBHOOK_SECRET=your_webhook_secret
PAYMENT_WEBHOOK_URL=https://yourapp.com/webhook/payment
KYC_WEBHOOK_URL=https://yourapp.com/webhook/kyc