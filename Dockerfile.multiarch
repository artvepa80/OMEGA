# OMEGA PRO AI v10.1 - BUILD MULTI-ARQUITECTURA
# Compatible con AMD64 y ARM64
FROM --platform=$TARGETPLATFORM python:3.13-slim

# Build arguments
ARG TARGETPLATFORM
ARG BUILDPLATFORM

# Build info
ENV OMEGA_VERSION=v10.1
ENV OMEGA_COMPLETE=true
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

# Print build info
RUN printf "🏗️ Building for TARGETPLATFORM=%s on BUILDPLATFORM=%s\n" "$TARGETPLATFORM" "$BUILDPLATFORM"

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3-dev \
    build-essential \
    git \
    curl \
    htop \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

WORKDIR /app

# Copy requirements first for better caching
COPY requirements*.txt ./

# Install Python packages with architecture-specific handling
RUN pip3 install --no-cache-dir --upgrade pip && \
    pip3 install --no-cache-dir torch torchvision --index-url https://download.pytorch.org/whl/cpu && \
    # TensorFlow installation based on architecture \
    if [ "$TARGETPLATFORM" = "linux/amd64" ]; then \
        pip3 install --no-cache-dir tensorflow-cpu; \
    else \
        pip3 install --no-cache-dir tensorflow; \
    fi && \
    pip3 install --no-cache-dir -r requirements.txt

# Copy ALL OMEGA PROJECT
COPY . /app/

# Create necessary directories
RUN mkdir -p logs outputs results temp export reports performance_reports

# Set permissions for executable files
RUN find /app -name "*.py" -exec chmod +x {} \; || true
RUN find /app -name "*.sh" -exec chmod +x {} \; || true

# Create optimized entrypoint
RUN echo '#!/bin/bash\necho "🚀 OMEGA PRO AI v${OMEGA_VERSION} - SISTEMA COMPLETO MULTI-ARCH"\necho "🏗️ Arquitectura: $(uname -m)"\necho "📋 Platform: $TARGETPLATFORM"\necho "💻 CPU: $(nproc) cores"\necho "🐍 Python: $(python3 --version)"\necho "📁 OMEGA COMPLETO en /app"\necho "📊 Archivos Python: $(find /app -name \"*.py\" 2>/dev/null | wc -l)"\necho "📦 Módulos: $(ls -1 /app/modules/ 2>/dev/null | wc -l)"\necho "🧠 Modelos: $(ls -1 /app/models/ 2>/dev/null | wc -l)"\necho "✅ Sistema listo para ejecución completa"\necho "================================================"\nexec "$@"' > entrypoint.sh && chmod +x entrypoint.sh

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python3 -c "import sys; sys.path.append('/app'); print('✅ OMEGA Complete Health OK')" || exit 1

# Default port
EXPOSE 8000

# Default command
CMD ["python3", "main.py", "--server-mode", "--port", "8000"]
ENTRYPOINT ["./entrypoint.sh"]