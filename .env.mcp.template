# OMEGA AI MCP Environment Configuration Template
# Copy this file to .env and fill in your credentials to enable MCP services

# =============================================================================
# GENERAL MCP SETTINGS
# =============================================================================
OMEGA_MCP_ENABLED=true
OMEGA_MCP_AUTO_START=false
OMEGA_API_BASE=http://localhost:8000
OMEGA_API_KEY=your_api_key_here

# =============================================================================
# TWILIO (WhatsApp Integration)
# =============================================================================
# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Twilio Sandbox number
# Your WhatsApp number for testing (include country code)
TEST_WHATSAPP=+1234567890

# =============================================================================
# TELEGRAM INTEGRATION
# =============================================================================
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Get your chat ID by messaging @userinfobot
TEST_TELEGRAM_CHAT_ID=your_chat_id_here

# =============================================================================
# EMAIL (SMTP) INTEGRATION
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=your_email@gmail.com
TEST_EMAIL=your_test_email@example.com

# =============================================================================
# DISCORD INTEGRATION
# =============================================================================
# Create a webhook in your Discord server
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# =============================================================================
# SLACK INTEGRATION
# =============================================================================
# Create a webhook in your Slack workspace
OMEGA_SLACK_WEBHOOK=https://hooks.slack.com/services/your_webhook_url

# =============================================================================
# MCP SERVICE CONFIGURATION
# =============================================================================
# Lottery data ingestion settings
OMEGA_LOTTERY_DATA_DIR=data/lottery_ingestion
OMEGA_LOTTERY_CACHE_ENABLED=true
OMEGA_LOTTERY_TIMEOUT_SECONDS=30

# Notification settings
OMEGA_NOTIFY_CONSOLE=1
OMEGA_NOTIFY_TIMEOUT=10
OMEGA_NOTIFY_MAX_RETRIES=3
OMEGA_NOTIFY_BACKOFF=1.5
OMEGA_NOTIFY_RECIPIENTS=your_email@example.com,+1234567890

# Workflow automation settings
OMEGA_WORKFLOW_TIMEZONE=America/Lima
OMEGA_WORKFLOW_MONITORING_INTERVAL=60
OMEGA_WORKFLOW_DEFAULT_LOTTERIES=kabala_pe

# Health monitoring
OMEGA_HEALTH_CHECK_ENABLED=true
OMEGA_HEALTH_CHECK_INTERVAL=300
OMEGA_HEALTH_ALERT_ON_FAILURE=true

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# Rate limiting
OMEGA_RATE_LIMIT_PER_MINUTE=10
OMEGA_RATE_LIMIT_PER_HOUR=100

# Data retention (days)
OMEGA_DATA_RETENTION_DAYS=30
OMEGA_LOG_RETENTION_DAYS=7

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Enable debug logging
OMEGA_DEBUG_ENABLED=false
# Test mode (uses sandbox APIs)
OMEGA_TEST_MODE=true