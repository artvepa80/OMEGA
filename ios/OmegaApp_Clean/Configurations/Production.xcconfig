//
//  Production.xcconfig
//  OMEGA Pro AI - Production Configuration
//
//  Production environment configuration with maximum security
//  and performance optimizations
//

// MARK: - App Configuration
PRODUCT_BUNDLE_IDENTIFIER = com.omega.OmegaApp
PRODUCT_NAME = OMEGA
CFBundleDisplayName = OMEGA PRO AI
MARKETING_VERSION = 1.0.0
CURRENT_PROJECT_VERSION = 1

// MARK: - Development Team & Code Signing
DEVELOPMENT_TEAM = PSXDB5A2NN
CODE_SIGN_IDENTITY = Apple Distribution
CODE_SIGN_STYLE = Manual
PROVISIONING_PROFILE_SPECIFIER = OMEGA Production Profile

// MARK: - Deployment
IPHONEOS_DEPLOYMENT_TARGET = 15.0
TARGETED_DEVICE_FAMILY = 1,2
SUPPORTS_MACCATALYST = NO

// MARK: - Compiler Settings
SWIFT_VERSION = 5.9
SWIFT_OPTIMIZATION_LEVEL = -O
SWIFT_ACTIVE_COMPILATION_CONDITIONS = PRODUCTION $(inherited)
SWIFT_EMIT_LOC_STRINGS = NO
ENABLE_TESTABILITY = NO

// MARK: - Production Release Settings
DEBUG_INFORMATION_FORMAT = dwarf-with-dsym
GCC_OPTIMIZATION_LEVEL = s
GCC_PREPROCESSOR_DEFINITIONS = PRODUCTION=1 NDEBUG=1 $(inherited)
ENABLE_NS_ASSERTIONS = NO
ONLY_ACTIVE_ARCH = NO
VALIDATE_PRODUCT = YES

// MARK: - Security Settings (Maximum)
ENABLE_HARDENED_RUNTIME = YES
ENABLE_BITCODE = YES
SWIFT_COMPILATION_MODE = wholemodule

// MARK: - SSL/TLS Configuration (Production)
// Use Akash Network production environment with strict SSL
OMEGA_API_BASE_URL = https://a17d0f2p7pbkp4bc0pjgbsmp8o.ingress.paradigmapolitico.online
OMEGA_ALLOW_INSECURE_HTTP = NO
OMEGA_SSL_PINNING_ENABLED = YES
OMEGA_ALLOW_SELF_SIGNED = NO
OMEGA_ENVIRONMENT = production

// MARK: - Build Settings
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon
ASSETCATALOG_COMPILER_GLOBAL_ACCENT_COLOR_NAME = AccentColor

// MARK: - Strip Settings (Production)
STRIP_INSTALLED_PRODUCT = YES
STRIP_STYLE = non-global
COPY_PHASE_STRIP = YES
STRIP_SWIFT_SYMBOLS = YES

// MARK: - Deployment Postprocessing
DEPLOYMENT_POSTPROCESSING = YES

// MARK: - Other Linker Flags
OTHER_LDFLAGS = $(inherited) -ObjC -Wl,-dead_strip

// MARK: - Info.plist Preprocessing
INFOPLIST_PREPROCESS = YES
INFOPLIST_PREFIX_HEADER = Configurations/Production-Info.pch

// MARK: - Custom Build Settings for OMEGA
OMEGA_ANALYTICS_ENABLED = YES
OMEGA_LOGGING_LEVEL = error
OMEGA_DEBUG_MENU_ENABLED = NO
OMEGA_CRASH_REPORTING = YES

// MARK: - App Store Optimization
ASSETCATALOG_COMPILER_OPTIMIZATION = time
COMPRESS_PNG_FILES = YES
REMOVE_STATIC_EXECUTABLES = YES

// MARK: - Code Signing Certificate Requirements
CODE_SIGN_INJECT_BASE_ENTITLEMENTS = YES
OTHER_CODE_SIGN_FLAGS = --timestamp --options=runtime

// MARK: - Security Hardening
ENABLE_USER_SCRIPT_SANDBOXING = YES
CLANG_ENABLE_OBJC_WEAK = YES
CLANG_WARN_SECURITY_SYNTAX_ANALYSIS = YES
CLANG_WARN_OBJC_ROOT_CLASS = YES_ERROR
CLANG_WARN_INFINITE_RECURSION = YES

// MARK: - Performance Optimization
MTL_FAST_MATH = YES
GCC_UNROLL_LOOPS = YES