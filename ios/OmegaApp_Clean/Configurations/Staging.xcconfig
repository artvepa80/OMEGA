//
//  Staging.xcconfig
//  OMEGA Pro AI - Staging Configuration
//
//  Staging environment configuration with production-like settings
//  but with additional debugging capabilities
//

// MARK: - App Configuration
PRODUCT_BUNDLE_IDENTIFIER = com.omega.OmegaApp.staging
PRODUCT_NAME = OMEGA STAGING
CFBundleDisplayName = OMEGA PRO AI (STAGING)
MARKETING_VERSION = 1.0.0
CURRENT_PROJECT_VERSION = 1

// MARK: - Development Team & Code Signing
DEVELOPMENT_TEAM = PSXDB5A2NN
CODE_SIGN_IDENTITY = Apple Development
CODE_SIGN_STYLE = Manual
PROVISIONING_PROFILE_SPECIFIER = OMEGA Staging Profile

// MARK: - Deployment
IPHONEOS_DEPLOYMENT_TARGET = 15.0
TARGETED_DEVICE_FAMILY = 1,2
SUPPORTS_MACCATALYST = NO

// MARK: - Compiler Settings
SWIFT_VERSION = 5.9
SWIFT_OPTIMIZATION_LEVEL = -O
SWIFT_ACTIVE_COMPILATION_CONDITIONS = STAGING $(inherited)
SWIFT_EMIT_LOC_STRINGS = YES
ENABLE_TESTABILITY = YES

// MARK: - Release Settings with Debug Info
DEBUG_INFORMATION_FORMAT = dwarf-with-dsym
GCC_OPTIMIZATION_LEVEL = s
GCC_PREPROCESSOR_DEFINITIONS = STAGING=1 $(inherited)
ENABLE_NS_ASSERTIONS = NO
ONLY_ACTIVE_ARCH = NO
VALIDATE_PRODUCT = YES

// MARK: - Security Settings (Production-like)
ENABLE_HARDENED_RUNTIME = YES
ENABLE_BITCODE = YES

// MARK: - SSL/TLS Configuration (Staging)
// Use Akash Network staging environment with SSL
OMEGA_API_BASE_URL = https://a17d0f2p7pbkp4bc0pjgbsmp8o.ingress.paradigmapolitico.online
OMEGA_ALLOW_INSECURE_HTTP = NO
OMEGA_SSL_PINNING_ENABLED = YES
OMEGA_ALLOW_SELF_SIGNED = YES
OMEGA_ENVIRONMENT = staging

// MARK: - Build Settings
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon-Staging
ASSETCATALOG_COMPILER_GLOBAL_ACCENT_COLOR_NAME = AccentColor-Staging

// MARK: - Strip Settings
STRIP_INSTALLED_PRODUCT = YES
STRIP_STYLE = debugging
COPY_PHASE_STRIP = NO

// MARK: - Other Linker Flags
OTHER_LDFLAGS = $(inherited) -ObjC

// MARK: - Info.plist Preprocessing
INFOPLIST_PREPROCESS = YES
INFOPLIST_PREFIX_HEADER = Configurations/Staging-Info.pch

// MARK: - Custom Build Settings for OMEGA
OMEGA_ANALYTICS_ENABLED = YES
OMEGA_LOGGING_LEVEL = info
OMEGA_DEBUG_MENU_ENABLED = YES
OMEGA_CRASH_REPORTING = YES

// MARK: - Code Signing Certificate Requirements
CODE_SIGN_INJECT_BASE_ENTITLEMENTS = YES
OTHER_CODE_SIGN_FLAGS = --timestamp