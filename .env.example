# 🚀 OMEGA PRO AI v10.1 - Environment Configuration Template
# Copy this file to .env and update with your actual values

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
PORT=8000

# ============================================================================
# AKASH NETWORK CONFIGURATION
# ============================================================================
# Get these values from your Akash wallet and deployment
AKASH_NODE=https://rpc.akashnet.net:443
AKASH_CHAIN_ID=akashnet-2
AKASH_ACCOUNT_ADDRESS=your_akash_address_here
AKASH_DSEQ=22849193
AKASH_PROVIDER=provider.akash.win
AKASH_URL=https://f4o5gi3c0tfmvblt4avi2l6o08.ingress.akash.win

# Akash wallet mnemonic (keep secure!)
AKASH_WALLET_MNEMONIC="your twelve word mnemonic phrase here for deployment automation"

# ============================================================================
# DOCKER CONFIGURATION
# ============================================================================
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_NAME=omegaproai/omega-ai
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_TOKEN=your_dockerhub_access_token

# ============================================================================
# GITHUB CONFIGURATION (For CI/CD)
# ============================================================================
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_REPOSITORY=yourusername/omega-pro-ai

# ============================================================================
# MONITORING & ALERTS
# ============================================================================
# Slack webhook for deployment notifications (optional)
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Monitoring settings
MONITOR_INTERVAL=60
ALERT_THRESHOLD=3
RESPONSE_TIME_THRESHOLD=10

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
# API Keys for external services (if needed)
OPENAI_API_KEY=your_openai_api_key_if_needed
ANTHROPIC_API_KEY=your_anthropic_api_key_if_needed

# JWT secret for API authentication (if implemented)
JWT_SECRET=your_super_secret_jwt_key_here

# Database encryption key (if using encrypted storage)
ENCRYPTION_KEY=your_encryption_key_for_sensitive_data

# ============================================================================
# DEVELOPMENT SETTINGS (Only for development)
# ============================================================================
# Set to true for development mode
DEV_MODE=false

# Local development database
DEV_DATABASE_URL=sqlite:///./dev_omega.db

# Enable debug logging in development
DEV_LOG_LEVEL=DEBUG

# ============================================================================
# PRODUCTION OPTIMIZATIONS
# ============================================================================
# Python optimizations
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Performance tuning
WORKERS=2
MAX_CONNECTIONS=100
TIMEOUT=300

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable specific AI features
ENABLE_ADVANCED_AI=true
ENABLE_META_LEARNING=true
ENABLE_AUTO_LEARNING=true
ENABLE_PARTIAL_HITS=true

# ============================================================================
# BACKUP & RECOVERY
# ============================================================================
# Backup settings (if implemented)
BACKUP_ENABLED=false
BACKUP_INTERVAL=daily
BACKUP_RETENTION_DAYS=30

# ============================================================================
# ADDITIONAL SERVICES
# ============================================================================
# Redis for caching (if using)
REDIS_URL=redis://localhost:6379

# PostgreSQL for advanced analytics (if using)
POSTGRES_URL=postgresql://user:pass@localhost:5432/omega

# ============================================================================
# DEPLOYMENT METADATA
# ============================================================================
DEPLOYMENT_VERSION=v10.1
DEPLOYMENT_DATE=2025-08-14
DEPLOYMENT_ENVIRONMENT=production